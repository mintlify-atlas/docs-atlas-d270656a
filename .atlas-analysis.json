  "keyFeatures": [
    "TypeScript-native infrastructure as code with zero additional tooling",
    "Async-first resource management with automatic lifecycle handling",
    "Multiple cloud providers (Cloudflare, AWS, Vercel, etc.) in one framework",
    "Built-in secret encryption and secure state management",
    "Framework integrations for Vite, Astro, Next.js, and more",
    "Local development mode with Miniflare for testing",
    "ESM-native and embeddable in any JavaScript runtime",
    "Extensible resource system for custom providers"
  ],
  "publicApiSurface": [
    "alchemy() - Main entry point for creating application scopes",
    "Resource() - Base function for creating custom resources",
    "Worker() - Deploy Cloudflare Workers",
    "DurableObjectNamespace() - Create Cloudflare Durable Objects",
    "Queue() - Create message queues",
    "R2Bucket() - Create object storage",
    "D1Database() - Create SQLite databases",
    "Workflow() - Create Cloudflare Workflows",
    "Function() - Deploy AWS Lambda functions",
    "Table() - Create DynamoDB tables",
    "alchemy.secret() - Create encrypted secrets",
    "alchemy.env() - Access environment variables",
    "Scope.finalize() - Complete resource lifecycle"
  ]
}
